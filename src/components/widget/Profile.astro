---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;
const aboutUrl = "https://paisl.cloud";
---
<div class="card-base p-4 md:p-5">
    <a aria-label="Visit PAISL main website" href={aboutUrl} target="_blank" rel="noreferrer"
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-[1.45rem] active:scale-95 border border-white/10 shadow-[0_20px_50px_rgba(2,8,24,0.45)]">
        <div class="absolute transition pointer-events-none group-hover:bg-[rgba(16,62,121,0.25)] group-active:bg-black/50
         w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa6-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <ImageWrapper src={config.avatar || ""} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0 aspect-[4/5]"></ImageWrapper>
    </a>
    <div class="px-2">
        <div class="font-bold text-[1.35rem] text-center mb-1 text-white transition tracking-tight">{config.name}</div>
        <div class="h-1 w-8 bg-gradient-to-r from-[var(--primary-deep)] to-[var(--primary)] mx-auto rounded-full mb-3 transition"></div>
        <div class="text-center text-slate-300 mb-2.5 transition leading-relaxed">{config.bio}</div>
        <div class="flex flex-wrap gap-2 justify-center mb-1">
            {config.links.length > 1 && config.links.map(item =>
                    <a rel="me" aria-label={item.name} href={item.url} target="_blank" class="btn-regular rounded-lg h-10 w-10 active:scale-90">
                        <Icon name={item.icon} class="text-[1.5rem]"></Icon>
                    </a>
            )}
            {config.links.length == 1 && <a rel="me" aria-label={config.links[0].name} href={config.links[0].url} target="_blank"
                                            class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95">
                <Icon name={config.links[0].icon} class="text-[1.5rem]"></Icon>
                {config.links[0].name}
            </a>}
        </div>
    </div>
</div>
