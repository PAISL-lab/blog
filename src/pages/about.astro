---
const aboutUrl = "https://paisl.cloud";
---

<!DOCTYPE html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="refresh" content={`0;url=${aboutUrl}`} />
		<meta name="robots" content="noindex" />
		<link rel="canonical" href={aboutUrl} />
		<title>Redirecting to PAISL</title>
	</head>
	<body>
		<script is:inline define:vars={{ aboutUrl }}>
			window.location.replace(aboutUrl);
		</script>
		<p>
			Redirecting to <a href={aboutUrl}>{aboutUrl}</a>
		</p>
	</body>
</html>
